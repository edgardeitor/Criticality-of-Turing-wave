         "[", "\"\<The file 'Variables.txt' could not be found. Run the \
Python script first.\>\"", "]"}], ";", "\[IndentingNewLine]", 
        RowBox[{"Quit", "[", "]"}]}]}], "\n", "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"var", "[", 
       RowBox[{"[", "varnum", "]"}], "]"}], "=", 
      RowBox[{"ToExpression", "[", 
