 RowBox[{
  RowBox[{
   RowBox[{"null", "[", "_String", "]"}], ":=", "Null"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"eqbool", "=", "1"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"If", "[", 
  RowBox[{
   RowBox[{"FileExistsQ", "[", "\"\<Kinetics.txt\>\"", "]"}], ",", 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"nvar", "=", 
     RowBox[{"Length", "@", 
      RowBox[{"ReadList", "[", 
       RowBox[{"\"\<Kinetics.txt\>\"", ",", 
        RowBox[{"null", "@", "String"}], ",", 
        RowBox[{"NullRecords", "->", "True"}]}], "]"}]}]}], ";"}], 
