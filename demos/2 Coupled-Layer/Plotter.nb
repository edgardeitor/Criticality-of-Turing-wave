    RowBox[{"If", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"ValueQ", "[", "nC5Bool114", "]"}], " ", "&&", " ", 
       RowBox[{"ValueQ", "[", "nC5Bool132", "]"}], " ", "&&", " ", 
       RowBox[{"nC5Bool114", ">", "0"}], " ", "&&", " ", 
       RowBox[{"nC5Bool132", ">", "0"}]}], ",", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"C114", "=", 
        RowBox[{"ToExpression", "[", 
         RowBox[{
         "Import", "[", "\"\<Fifth-order coefficient C114.txt\>\"", "]"}], 
         "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"C132", "=", 
