         RowBox[{
         "Import", "[", "\"\<Fifth-order coefficient C132.txt\>\"", "]"}], 
         "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"fifthcoeff132", "=", 
        RowBox[{"{", "}"}]}], ";"}]}], "\[IndentingNewLine]", "]"}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{"codimensiontwo130", "=", 
     RowBox[{"{", "}"}]}], ";", "\[IndentingNewLine]", 
    RowBox[{"codimensiontwo112", "=", 
     RowBox[{"{", "}"}]}], ";", "\[IndentingNewLine]", 
    RowBox[{"For", "[", 
     RowBox[{
      RowBox[{"outersolnum", "=", "1"}], ",", 
      RowBox[{"outersolnum", "<=", 
       RowBox[{"Length", "[", "solutioncurves", "]"}]}], ",", 
      RowBox[{"outersolnum", "++"}], ",", "\[IndentingNewLine]", 
      RowBox[{"For", "[", 
       RowBox[{
        RowBox[{"innersolnum", "=", "1"}], ",", 
        RowBox[{"innersolnum", "<=", 
