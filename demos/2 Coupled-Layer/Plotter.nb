e01c0e2cd7d8"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"timedifference", "=", "1"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"tol", "=", 
   SuperscriptBox["10", 
    RowBox[{"-", "6"}]]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"criticalitybool", "=", 
   RowBox[{
   "Import", "[", "\"\<Find codimension-two bifurcation points.txt\>\"", 
    "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"If", "[", 
  RowBox[{
   RowBox[{
    RowBox[{"ToString", "[", "criticalitybool", "]"}], "==", "\"\<y\>\""}], ",",
    "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"If", "[", 
     RowBox[{
      RowBox[{
      "FileExistsQ", "[", "\"\<Fifth-order coefficient C150.txt\>\"", "]"}], ",",
       "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"nC5Bool", "=", 
        RowBox[{"Length", "@", 
         RowBox[{"ReadList", "[", 
          RowBox[{"\"\<Fifth-order coefficient C150.txt\>\"", ",", 
           RowBox[{"null", "@", "String"}], ",", 
           RowBox[{"NullRecords", "->", "True"}]}], "]"}]}]}], ";"}]}], 
     "\[IndentingNewLine]", "]"}], ";", "\[IndentingNewLine]", 
    RowBox[{"If", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"ValueQ", "[", "nC5Bool", "]"}], " ", "&&", " ", 
       RowBox[{"nC5Bool", ">", "0"}]}], ",", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"C150", "=", 
        RowBox[{"ToExpression", "[", 
         RowBox[{
         "Import", "[", "\"\<Fifth-order coefficient C150.txt\>\"", "]"}], 
         "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"fifthcoeff150", "=", 
        RowBox[{"{", "}"}]}], ";"}]}], "\[IndentingNewLine]", "]"}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{"If", "[", 
     RowBox[{
      RowBox[{
       RowBox[{
       "FileExistsQ", "[", "\"\<Fifth-order coefficient C114.txt\>\"", "]"}], 
       " ", "&&", " ", 
       RowBox[{
       "FileExistsQ", "[", "\"\<Fifth-order coefficient C132.txt\>\"", 
        "]"}]}], ",", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"nC5Bool114", "=", 
        RowBox[{"Length", "@", 
         RowBox[{"ReadList", "[", 
          RowBox[{"\"\<Fifth-order coefficient C114.txt\>\"", ",", 
