 RowBox[{
  RowBox[{"var", "=", 
   RowBox[{"Range", "[", "nvar", "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"For", "[", 
   RowBox[{
    RowBox[{"varnum", "=", "1"}], ",", 
    RowBox[{"varnum", "<=", "nvar"}], ",", 
    RowBox[{"varnum", "++"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{
      RowBox[{"kinetics", "[", 
       RowBox[{"[", "varnum", "]"}], "]"}], "=", 
      RowBox[{"ToExpression", "[", 
       RowBox[{"ReadLine", "[", "\"\<Kinetics.txt\>\"", "]"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{"FileExistsQ", "[", "\"\<Variables.txt\>\"", "]"}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{
         RowBox[{"var", "[", 
          RowBox[{"[", "varnum", "]"}], "]"}], "=", 
         RowBox[{"ReadLine", "[", "\"\<Variables.txt\>\"", "]"}]}], ";"}], 
