Cell[CellGroupData[{

Cell["Cross-order coefficient", "Title",
 CellChangeTimes->{{3.9084697860435953`*^9, 
  3.908469789611486*^9}},ExpressionUUID->"953b852f-e1cf-4ba6-929b-\
a9b3f16886cb"],

Cell[BoxData[
 RowBox[{"If", "[", 
  RowBox[{
   RowBox[{"\[Not]", 
    RowBox[{
    "FileExistsQ", "[", "\"\<To get cross-order coefficient.txt\>\"", "]"}]}],
    ",", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Throw", "[", "\"\<The cross-order coefficient will not be computed\>\"", 
     "]"}], ";"}], "\[IndentingNewLine]", ",", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"For", "[", 
     RowBox[{
      RowBox[{"counter", "=", "1"}], ",", 
      RowBox[{"counter", "<=", "2"}], ",", 
      RowBox[{"counter", "++"}], ",", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"aux", "=", 
        RowBox[{
        "ReadLine", "[", "\"\<To get cross-order coefficient.txt\>\"", 
         "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"counter", "==", "1"}], ",", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"crosspar", "=", 
           RowBox[{"ToExpression", "[", "aux", "]"}]}], ";"}], 
         "\[IndentingNewLine]", ",", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"C11", "=", 
           RowBox[{"ToExpression", "[", "aux", "]"}]}], ";"}]}], 
        "\[IndentingNewLine]", "]"}]}]}], "\[IndentingNewLine]", "]"}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{"Close", "[", "\"\<To get cross-order coefficient.txt\>\"", "]"}],
     ";", "\[IndentingNewLine]", 
    RowBox[{"C11", "=", 
     RowBox[{"C11", "/.", "eq"}]}], ";", "\[IndentingNewLine]", 
    RowBox[{"C11", "=", 
     RowBox[{"D", "[", 
      RowBox[{"C11", ",", "crosspar"}], "]"}]}], ";", "\[IndentingNewLine]", 
    RowBox[{"C11", "=", 
     RowBox[{"C11", "/.", 
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"ToExpression", "[", 
          RowBox[{
           RowBox[{"ToString", "[", "phi11NF", "]"}], " ", "<>", " ", 
           RowBox[{"ToString", "[", 
            RowBox[{"coordnum", "-", "1"}], "]"}]}], "]"}], "->", 
         RowBox[{"phi11NFeval", "[", 
          RowBox[{"[", "coordnum", "]"}], "]"}]}], ",", 
        RowBox[{"{", 
         RowBox[{"coordnum", ",", "nvar"}], "}"}]}], "]"}]}]}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{"C11", "=", 
     RowBox[{"C11", "/.", 
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"ToExpression", "[", 
          RowBox[{
           RowBox[{"ToString", "[", "psi11NF", "]"}], " ", "<>", " ", 
           RowBox[{"ToString", "[", 
            RowBox[{"coordnum", "-", "1"}], "]"}]}], "]"}], "->", 
         RowBox[{"psi11NFeval", "[", 
          RowBox[{"[", "coordnum", "]"}], "]"}]}], ",", 
        RowBox[{"{", 
         RowBox[{"coordnum", ",", "nvar"}], "}"}]}], "]"}]}]}], ";"}]}], 
  "\[IndentingNewLine]", "]"}]], "Input",
 CellChangeTimes->{
  3.908470215481806*^9, {3.927742828749226*^9, 3.9277428930792413`*^9}, {
   3.9278367061472855`*^9, 3.927836708831275*^9}, {3.933026529052183*^9, 
